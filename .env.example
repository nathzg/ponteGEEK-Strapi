# Server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=

# App Keys (obligatorio - 4 valores separados por coma)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
ADMIN_ENCRYPTION_KEY=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# Base de datos SQLite (better-sqlite3)
# Local: .tmp/data.db | Railway con Volume: /data/data.db
DATABASE_FILENAME=.tmp/data.db

# AWS S3 (uploads)
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=
AWS_BUCKET=
